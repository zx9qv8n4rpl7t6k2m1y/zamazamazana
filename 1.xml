<script>
var CDN         = "https://cdn.jsdelivr.net/gh/papamamia/zamazamazana@main/Build";          /* <-- degistir */
var SA_CDN      = "https://cdn.jsdelivr.net/gh/papamamia/zamazamazana@main/StreamingAssets"; /* <-- degistir */
var DATA_PARTS  = 4;  /* 28.3MB / 8MB = 4 part */
var BUNDLE_FILE = "aa/WebGL/default_assets_all_86e6c689539c8f4b2be0ff2e56740e33.bundle";
var BUNDLE_PARTS= 6;  /* 43.45MB / 8MB = 6 part */

var container        = document.querySelector("#unity-container");
